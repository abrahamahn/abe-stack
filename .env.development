# .env.development
# Server config
NODE_ENV=development
PORT=8080
HOST=localhost

# Database config
DB_HOST=localhost
DB_PORT=5432
DB_NAME=abe_stack
DB_USER=postgres
DB_PASSWORD=postgres

# Auth config
JWT_SECRET=development-jwt-secret-key-change-in-production
JWT_EXPIRATION=7d

# CORS
CORS_ORIGINS=http://localhost:3000

# Client variables (for Vite)
VITE_NODE_ENV=development
VITE_API_URL=/api
VITE_APP_TITLE=ABE Stack (Development)